meta {
  name: DELETE Articulo Venta
  type: http
  seq: 5
}

delete {
  url: {{base_url}}/articulos-venta
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "id": 1
  }
}

script:post-response {
  if (res.status === 200) {
    console.log("Artículo de venta eliminado exitosamente");
  } else {
    console.log("Error:", res.status, res.body);
  }
}
