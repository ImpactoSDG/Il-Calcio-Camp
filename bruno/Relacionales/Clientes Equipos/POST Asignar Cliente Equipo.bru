meta {
  name: POST Asignar Cliente Equipo
  type: http
  seq: 1
}

post {
  url: {{base_url}}/clientes-equipos
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "id_cliente_equipo": 1,
    "id_cliente": 27123456,
    "id_equipo": 1
  }
}

script:post-response {
  if (res.status === 201) {
    console.log("Cliente asignado a equipo exitosamente");
  } else {
    console.log("Error:", res.status, res.body);
  }
}
