meta {
  name: GET by Cliente
  type: http
  seq: 3
}

get {
  url: {{base_url}}/clientes-equipos?cliente=27123456
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

script:post-response {
  if (res.status === 200) {
    console.log("Equipos del cliente:", res.body.length);
  } else {
    console.log("Error:", res.status);
  }
}
