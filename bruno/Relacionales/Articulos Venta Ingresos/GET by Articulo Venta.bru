meta {
  name: GET by Articulo Venta
  type: http
  seq: 3
}

get {
  url: {{base_url}}/articulos-venta-ingresos?articulo_venta=1
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

script:post-response {
  if (res.status === 200) {
    console.log("Ingresos del artículo de venta:", res.body.length);
  } else {
    console.log("Error:", res.status);
  }
}
