meta {
  name: GET by Venta
  type: http
  seq: 3
}

get {
  url: {{base_url}}/ventas-cobro?venta=1
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

script:post-response {
  if (res.status === 200) {
    console.log("Cobros de la venta:", res.body.length);
  } else {
    console.log("Error:", res.status);
  }
}
