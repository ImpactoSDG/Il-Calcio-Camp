meta {
  name: DELETE Venta Cobro
  type: http
  seq: 6
}

delete {
  url: {{base_url}}/ventas-cobro
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "id_venta_cobro": 1
  }
}

script:post-response {
  if (res.status === 200) {
    console.log("Relación venta-cobro eliminada exitosamente");
  } else {
    console.log("Error:", res.status, res.body);
  }
}
