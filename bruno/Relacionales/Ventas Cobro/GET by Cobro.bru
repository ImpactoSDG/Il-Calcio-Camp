meta {
  name: GET by Cobro
  type: http
  seq: 4
}

get {
  url: {{base_url}}/ventas-cobro?cobro=1
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

script:post-response {
  if (res.status === 200) {
    console.log("Ventas del cobro:", res.body.length);
  } else {
    console.log("Error:", res.status);
  }
}
