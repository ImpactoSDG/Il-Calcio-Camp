meta {
  name: PUT Update Venta Cobro
  type: http
  seq: 5
}

put {
  url: {{base_url}}/ventas-cobro
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "id_venta_cobro": 1,
    "id_venta": 1,
    "id_cobro": 1,
    "id_medio_pago": 1,
    "monto": 80000.00
  }
}

script:post-response {
  if (res.status === 200) {
    console.log("Relación venta-cobro actualizada exitosamente");
  } else {
    console.log("Error:", res.status, res.body);
  }
}
