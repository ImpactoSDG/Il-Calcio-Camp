meta {
  name: GET Equipos by Disciplina
  type: http
  seq: 4
}

get {
  url: {{base_url}}/equipos?disciplina=Fútbol
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

script:post-response {
  if (res.status === 200) {
    console.log("Equipos de fútbol obtenidos:", res.body.length);
  } else {
    console.log("Error:", res.status);
  }
}
