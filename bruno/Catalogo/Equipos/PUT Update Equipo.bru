meta {
  name: PUT Update Equipo
  type: http
  seq: 5
}

put {
  url: {{base_url}}/equipos
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "id": 1,
    "nombre": "Juveniles Sub-16 Categoría A",
    "disciplina": "Fútbol",
    "activo": true
  }
}

script:post-response {
  if (res.status === 200) {
    console.log("Equipo actualizado exitosamente");
  } else {
    console.log("Error:", res.status, res.body);
  }
}
