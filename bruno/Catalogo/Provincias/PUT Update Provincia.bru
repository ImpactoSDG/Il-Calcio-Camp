meta {
  name: PUT Update Provincia
  type: http
  seq: 4
}

put {
  url: {{base_url}}/provincias
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "id": 1,
    "provincia": "Córdoba Capital"
  }
}

script:post-response {
  if (res.status === 200) {
    console.log("Provincia actualizada exitosamente");
  } else {
    console.log("Error:", res.status, res.body);
  }
}
