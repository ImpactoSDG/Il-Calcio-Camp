meta {
  name: POST Create Provincia
  type: http
  seq: 1
}

post {
  url: {{base_url}}/provincias
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "id": 1,
    "provincia": "Córdoba"
  }
}

script:post-response {
  if (res.status === 201) {
    console.log("Provincia creada exitosamente");
  } else {
    console.log("Error:", res.status, res.body);
  }
}
