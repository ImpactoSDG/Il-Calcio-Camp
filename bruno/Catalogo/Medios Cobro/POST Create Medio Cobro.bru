meta {
  name: POST Create Medio Cobro
  type: http
  seq: 1
}

post {
  url: {{base_url}}/medios-cobro
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "id": 1,
    "descripcion": "Efectivo",
    "activo": true
  }
}

script:post-response {
  if (res.status === 201) {
    console.log("Medio de cobro creado exitosamente");
  } else {
    console.log("Error:", res.status, res.body);
  }
}
