meta {
  name: GET All Medios Cobro
  type: http
  seq: 2
}

get {
  url: {{base_url}}/medios-cobro
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

script:post-response {
  if (res.status === 200) {
    console.log("Medios de cobro obtenidos:", res.body.length);
  } else {
    console.log("Error:", res.status);
  }
}
