meta {
  name: GET Condicion IVA by ID
  type: http
  seq: 3
}

get {
  url: {{base_url}}/condiciones-iva/1
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

script:post-response {
  if (res.status === 200) {
    console.log("Condición IVA encontrada:", res.body);
  } else if (res.status === 404) {
    console.log("Condición IVA no encontrada");
  } else {
    console.log("Error:", res.status);
  }
}
