meta {
  name: PUT Update Condicion IVA
  type: http
  seq: 4
}

put {
  url: {{base_url}}/condiciones-iva
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "id": 1,
    "descripcion_condicion": "Responsable Inscripto Activo"
  }
}

script:post-response {
  if (res.status === 200) {
    console.log("Condición IVA actualizada exitosamente");
  } else {
    console.log("Error:", res.status, res.body);
  }
}
