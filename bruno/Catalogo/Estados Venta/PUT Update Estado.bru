meta {
  name: PUT Update Estado
  type: http
  seq: 4
}

put {
  url: {{base_url}}/estados-venta
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "id": 1,
    "descripcion": "Cerrada"
  }
}

script:post-response {
  if (res.status === 200) {
    console.log("Estado actualizado exitosamente");
  } else {
    console.log("Error:", res.status, res.body);
  }
}
