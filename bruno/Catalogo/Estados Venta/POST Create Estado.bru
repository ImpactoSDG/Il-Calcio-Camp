meta {
  name: POST Create Estado
  type: http
  seq: 1
}

post {
  url: {{base_url}}/estados-venta
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "descripcion": "Abierta"
  }
}

script:post-response {
  if (res.status === 201) {
    console.log("Estado creado con ID:", res.body.id);
  } else {
    console.log("Error:", res.status, res.body);
  }
}
