meta {
  name: POST Create Categoria
  type: http
  seq: 1
}

post {
  url: {{base_url}}/categorias-articulo
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "descripcion": "Equipamiento Deportivo"
  }
}

script:post-response {
  if (res.status === 201) {
    console.log("Categoría creada con ID:", res.body.id);
  } else {
    console.log("Error:", res.status, res.body);
  }
}
