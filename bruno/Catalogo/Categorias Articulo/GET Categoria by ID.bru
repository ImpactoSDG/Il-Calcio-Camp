meta {
  name: GET Categoria by ID
  type: http
  seq: 3
}

get {
  url: {{base_url}}/categorias-articulo/1
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

script:post-response {
  if (res.status === 200) {
    console.log("Categoría encontrada:", res.body);
  } else if (res.status === 404) {
    console.log("Categoría no encontrada");
  } else {
    console.log("Error:", res.status);
  }
}
