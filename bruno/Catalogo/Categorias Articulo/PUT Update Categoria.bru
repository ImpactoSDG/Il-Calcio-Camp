meta {
  name: PUT Update Categoria
  type: http
  seq: 4
}

put {
  url: {{base_url}}/categorias-articulo
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "id": 1,
    "descripcion": "Equipamiento Deportivo Profesional"
  }
}

script:post-response {
  if (res.status === 200) {
    console.log("Categoría actualizada exitosamente");
  } else {
    console.log("Error:", res.status, res.body);
  }
}
