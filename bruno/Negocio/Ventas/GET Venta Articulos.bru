meta {
  name: GET Venta Articulos
  type: http
  seq: 4
}

get {
  url: {{base_url}}/ventas/1?action=articulos
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

script:post-response {
  if (res.status === 200) {
    console.log("Artículos de la venta:", res.body.length);
  } else {
    console.log("Error:", res.status);
  }
}
