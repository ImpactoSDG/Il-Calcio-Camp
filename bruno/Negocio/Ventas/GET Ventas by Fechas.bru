meta {
  name: GET Ventas by Fechas
  type: http
  seq: 3
}

get {
  url: {{base_url}}/ventas?fecha_desde=2026-03-01&fecha_hasta=2026-03-31
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

script:post-response {
  if (res.status === 200) {
    console.log("Ventas en el período:", res.body.length);
  } else {
    console.log("Error:", res.status);
  }
}
