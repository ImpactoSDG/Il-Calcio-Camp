meta {
  name: GET Cobro by ID
  type: http
  seq: 4
}

get {
  url: {{base_url}}/cobros/1
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

script:post-response {
  if (res.status === 200) {
    console.log("Cobro encontrado:", res.body);
  } else if (res.status === 404) {
    console.log("Cobro no encontrado");
  } else {
    console.log("Error:", res.status);
  }
}
