meta {
  name: POST Create Cobro
  type: http
  seq: 1
}

post {
  url: {{base_url}}/cobros
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "id": 1,
    "cliente_id": 27123456
  }
}

script:post-response {
  if (res.status === 201) {
    console.log("Cobro creado exitosamente");
  } else {
    console.log("Error:", res.status, res.body);
  }
}
