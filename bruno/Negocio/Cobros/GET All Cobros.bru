meta {
  name: GET All Cobros
  type: http
  seq: 2
}

get {
  url: {{base_url}}/cobros
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

script:post-response {
  if (res.status === 200) {
    console.log("Cobros obtenidos:", res.body.length);
  } else {
    console.log("Error:", res.status);
  }
}
