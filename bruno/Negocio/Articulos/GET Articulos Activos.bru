meta {
  name: GET Articulos Activos
  type: http
  seq: 3
}

get {
  url: {{base_url}}/articulos?activos=1
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

script:post-response {
  if (res.status === 200) {
    console.log("Artículos activos obtenidos:", res.body.length);
  } else {
    console.log("Error:", res.status);
  }
}
