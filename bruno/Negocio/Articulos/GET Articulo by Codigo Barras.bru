meta {
  name: GET Articulo by Codigo Barras
  type: http
  seq: 4
}

get {
  url: {{base_url}}/articulos?cod_barra=7790001234567
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

script:post-response {
  if (res.status === 200) {
    console.log("Artículo encontrado:", res.body);
  } else if (res.status === 404) {
    console.log("Artículo no encontrado");
  } else {
    console.log("Error:", res.status);
  }
}
