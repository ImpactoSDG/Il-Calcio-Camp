# Configuración de la base de datos de TEST (local).
# Copiar este archivo a api/.env.testing y ajustar según tu entorno.
#
# IMPORTANTE: DB_NAME DEBE contener la palabra 'test'. Los tests de integración
# se niegan a correr contra cualquier otra base (salvaguarda anti-producción).
#
# Pasos:
#   1. Crear la base:  CREATE DATABASE il_calcio_camp_test;
#   2. Cargarle el schema (por ejemplo, una copia de la estructura de producción).
#   3. Ejecutar:  composer test

DB_HOST=127.0.0.1
DB_NAME=il_calcio_camp_test
DB_USER=root
DB_PASS=
